MSSQL_DATABASES=db1,db2,db3
MSSQL_SERVER=your-server.database.windows.net
MSSQL_USER=your-username
MSSQL_PASSWORD=your-password
MSSQL_PORT=1433
# Set to true to trust a self-signed server certificate.
MSSQL_TRUST_SERVER_CERTIFICATE=false
# Set to false for old on-prem servers that can't negotiate TLS.
MSSQL_ENCRYPT=true

# Optional SSH tunnel. Set MSSQL_SSH_HOST to reach a database behind a bastion;
# the server connects through a local port forward to MSSQL_SERVER:MSSQL_PORT.
MSSQL_SSH_HOST=
MSSQL_SSH_USER=
MSSQL_SSH_PORT=22
MSSQL_SSH_PASSWORD=
# Optional one-shot command run on the bastion before any query
MSSQL_SSH_STARTUP_COMMAND=
